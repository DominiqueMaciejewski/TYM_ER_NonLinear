  abstract = {Emotion regulation (ER) variability has received increased attention given its potential affective benefits, but the substantial differences in its conceptualization and operation across studies are a threat to theoretical precision. This study directly compared six indices of between-strategy ER variability—standard deviation (SD), standard deviation controlling for mean (SDM), relative standard deviation (RSD), coefficient of variation (CV), and Bray–Curtis dissimilarity (BC-D; replacement and nestedness components)—in relation to negative affect (NA).},
